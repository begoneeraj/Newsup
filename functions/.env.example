# Copy to .env (or .env.local for emulator-only overrides) -- both are
# gitignored. Firebase CLI loads these into process.env before the functions
# code runs, which is what firebase-functions/params' defineString() reads.

# Base URL of the deployed src/api_server.py service (Cloud Run or similar).
# No trailing slash, no path -- crisisClassifier.ts appends "/classify".
GROQ_PROCESSOR_URL=https://newsup-classifier-xxxxx.a.run.app

# Optional. Must match API_SHARED_SECRET on the Python service if that's
# set. Leave blank if the service is already private (e.g. IAM-gated Cloud
# Run) rather than relying on a shared secret.
GROQ_PROCESSOR_API_KEY=
